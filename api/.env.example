PORT=3000

DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host/your_db_name?sslmode=require
DATABASE_SSL=true

CORS_ORIGIN=http://localhost:5173

# Full public URL of the PWA — used as click-through URL in push notification payloads
APP_BASE_URL=https://your-pwa.onrender.com

# Change the slug here for future tournaments instead of editing three service files
ESPN_LEAGUE_SLUG=fifa.world
ESPN_WC_DATE_RANGE=20260611-20260719
ESPN_FETCH_LIMIT=200

# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:you@example.com

CRON_SECRET=your_random_cron_secret
# Reminder dispatch window in minutes — must be >= your scheduler's call interval
CRON_SLACK_MINUTES=12
