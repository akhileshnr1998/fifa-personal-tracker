{
  "name": "fifa-2026-api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.1 <23",
    "npm": ">=10"
  },
  "scripts": {
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "migration:run": "node ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:run:local": "npm run build && node --env-file=.env ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:revert": "npm run build && node --env-file=.env ./node_modules/typeorm/cli.js migration:revert -d dist/database/data-source.js",
    "migration:show": "npm run build && node --env-file=.env ./node_modules/typeorm/cli.js migration:show -d dist/database/data-source.js"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/web-push": "^3.6.4",
    "axios": "^1.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.21",
    "typescript": "^5.7.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2"
  }
}
